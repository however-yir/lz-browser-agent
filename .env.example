# LZ Browser Agent Configuration
# 复制为 .env 后按需修改。仅示例，不要提交真实密钥。

# ------------------------------------------------------------
# 1) Logging / Logging Level
# ------------------------------------------------------------
BROWSER_USE_LOGGING_LEVEL=info
BROWSER_USE_DEBUG_LOG_FILE=debug.log
BROWSER_USE_INFO_LOG_FILE=info.log
CDP_LOGGING_LEVEL=WARNING

# ------------------------------------------------------------
# 2) Telemetry / Analytics
# ------------------------------------------------------------
# true: 允许匿名统计
# false: 关闭匿名统计（建议私有部署默认关闭）
ANONYMIZED_TELEMETRY=false

# ------------------------------------------------------------
# 3) Cloud / API Access
# ------------------------------------------------------------
# 云端 API Key（仅在使用云能力时需要）
# 新命名空间变量（推荐）
LZ_BROWSER_AGENT_API_KEY=replace_with_your_key
# 兼容旧变量（可选，已兼容）
# BROWSER_USE_API_KEY=replace_with_your_key
# 自建或私有网关地址（可选）
# BROWSER_USE_CLOUD_API_URL=https://api.example.com
# BROWSER_USE_CLOUD_SYNC=false

# ------------------------------------------------------------
# 4) Local LLM & OpenAI-Compatible Endpoints
# ------------------------------------------------------------
# OpenAI 兼容地址（如 SiliconFlow / vLLM / OneAPI）
OPENAI_API_KEY=replace_with_openai_compatible_key
OPENAI_BASE_URL=http://127.0.0.1:8000/v1
# LZ Browser Agent 私有兼容网关（可选）
# LZ_BROWSER_AGENT_LLM_URL=https://llm-gateway.example.com/v1

# Anthropic / Google / Azure（可选）
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=

# Ollama 本地模型（新变量优先，旧变量兼容）
LZ_BROWSER_AGENT_OLLAMA_HOST=http://127.0.0.1:11434
# BROWSER_USE_OLLAMA_HOST=http://127.0.0.1:11434
BROWSER_USE_OLLAMA_MODEL=qwen2.5:7b-instruct

# 示例脚本默认任务（examples/common/local_runtime.py 会读取）
BROWSER_USE_DEFAULT_TASK=请在浏览器中打开目标页面并提取关键信息

# ------------------------------------------------------------
# 5) Database / Redis (for extended local workflows)
# ------------------------------------------------------------
# 当前仓库核心逻辑不强依赖数据库，以下用于你二开扩展
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/lz_browser_agent
REDIS_URL=redis://127.0.0.1:6379/0

# ------------------------------------------------------------
# 6) Browser Runtime
# ------------------------------------------------------------
# BROWSER_USE_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# BROWSER_USE_HEADLESS=false
# BROWSER_USE_USER_DATA_DIR=./browser_data

# Proxy
# BROWSER_USE_PROXY_SERVER=http://127.0.0.1:7890
# BROWSER_USE_NO_PROXY=localhost,127.0.0.1,*.internal
# BROWSER_USE_PROXY_USERNAME=username
# BROWSER_USE_PROXY_PASSWORD=password

# ------------------------------------------------------------
# 7) Version Check
# ------------------------------------------------------------
# 是否检查新版本
BROWSER_USE_VERSION_CHECK=true
